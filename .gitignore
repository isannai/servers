# build output (rebuild with build/<os>/build.*)
/build/out/
/build/linux/out/
/build/windows/out/

# runtime state
deploy/*/db/
deploy/*/data/
deploy/*/logs/
*.db
*.db-*

# TLS material — never commit
deploy/*/certs/*
!deploy/*/certs/.gitkeep
/certs/

# stray local binaries
/market
/market.exe
/rendezvous
/rendezvous.exe
